# ─── LedGuard Production Environment Variables ─────────────────────────────────
# Copy this file and fill in the values before deploying to Coolify.
# Set all these as environment variables in Coolify's service configuration.

# ── Database (Coolify-managed PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://medusa:STRONG_PASSWORD@postgres:5432/ledguard

# ── Redis (Coolify-managed Redis) ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Medusa Secrets (generate random 64-char strings) ──────────────────────────
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
COOKIE_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_CHAR_STRING

# ── CORS (match your actual domains) ──────────────────────────────────────────
STORE_CORS=https://ledguard.pl,https://www.ledguard.pl
ADMIN_CORS=https://admin.ledguard.pl
AUTH_CORS=https://ledguard.pl,https://admin.ledguard.pl

# ── Stripe (live keys from dashboard.stripe.com) ──────────────────────────────
STRIPE_API_KEY=sk_live_REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_STRIPE_WEBHOOK_SECRET

# ── Storefront public env vars ─────────────────────────────────────────────────
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.ledguard.pl
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_WITH_PUBLISHABLE_KEY_FROM_MEDUSA_ADMIN
NEXT_PUBLIC_DEFAULT_REGION=pl
NEXT_PUBLIC_BASE_URL=https://ledguard.pl
NEXT_PUBLIC_STRIPE_KEY=pk_live_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
